{
    "name": "brand7n/picohp",
    "description": "picoHP compiler",
    "keywords": ["php", "compiler", "php compiler", "console", "cli"],
    "homepage": "https://github.com/brand7n/picohp",
    "type": "project",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/brand7n/picohp/issues",
        "source": "https://github.com/brand7n/picohp"
    },
    "authors": [
        {
            "name": "Brandin L Claar",
            "email": "brandin@remodulate.com"
        }
    ],
    "require": {
        "php": "^8.5",
        "nikic/php-parser": "^5.7",
        "phpstan/phpdoc-parser": "^2.3",
        "ext-dom": "*",
        "ext-mbstring": "*",
        "ext-xml": "*"
    },
    "require-dev": {
        "brainmaestro/composer-git-hooks": "^3.0",
        "laravel/pint": "^1.18.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.5.1",
        "phpstan/phpstan": "^2.1",
        "phpstan/phpstan-strict-rules": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "bootstrap/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "phpstan": "php -d memory_limit=-1 vendor/bin/phpstan analyse --configuration phpstan.neon",
        "pest": "vendor/bin/pest",
        "coverage": "php -d pcov.directory=app vendor/bin/pest --coverage",
        "mutate": [
            "Composer\\Config::disableProcessTimeout",
            "vendor/bin/pest --mutate"
        ],
        "pint": "vendor/bin/pint",
        "smoke-build": "./picohp build tests/programs/smoke/word_scan_smoke.php",
        "smoke-precompile": "./picohp build tests/fixtures/precompile_smoke --precompile-plan --entry=src/main.php",
        "check": [
            "@phpstan",
            "@pest",
            "vendor/bin/pint --test"
        ],
        "all": [
            "@phpstan",
            "@pest",
            "@pint"
        ]
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["picohp"],
    "extra": {
        "hooks": {
            "config": {
                "stop-on-failure": ["pre-commit"]
            },
            "pre-commit": [
                "composer run-script check"
            ]
        }
    }
}
